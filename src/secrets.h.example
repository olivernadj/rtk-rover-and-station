#pragma once

// ── WiFi ────────────────────────────────────────────────────────────────────
struct WifiCredential {
    const char* ssid;
    const char* password;
};

extern const WifiCredential WIFI_CREDENTIALS[];
extern const int             WIFI_CREDENTIAL_COUNT;

// ── MQTT ─────────────────────────────────────────────────────────────────────
extern const char* MQTT_HOST;
extern const int   MQTT_PORT;

// ── NTRIP broadcaster (stationary only) ─────────────────────────────────────
#ifdef MODE_STATIONARY
struct NtripCasterConfig {
    const char* host;
    int         port;
    const char* mountpoint;
    const char* user;
    const char* password;
};

extern const NtripCasterConfig NTRIP_CASTERS[];
extern const int               NTRIP_CASTER_COUNT;
#endif

// ── NTRIP client (rover only) ────────────────────────────────────────────────
#ifdef MODE_ROVER
extern const char* NTRIP_HOST;
extern const int   NTRIP_PORT;
extern const char* NTRIP_MOUNTPOINT;
extern const char* NTRIP_USER;
extern const char* NTRIP_PASSWORD;
#endif

// ── OTA firmware update (when OTA_ENABLED) ──────────────────────────────────
#ifdef OTA_ENABLED
extern const char* OTA_USER;
extern const char* OTA_PASSWORD;
#endif
